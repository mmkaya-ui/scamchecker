{
  "name": "trustedlens",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "https-proxy-agent": "^7.0.5",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1",
    "puppeteer": "^22.12.1",
    "socks-proxy-agent": "^8.0.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.3.1"
  }
}
